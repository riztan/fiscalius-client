procedure __CxcGenerarPDF( aData,cCliente,cDocumento )

   local oPDF
  
   local nY := 1
   local nTotMto := 0,nTotApli := 0,nTotSal := 0
   local cFilePDF := "tmp/vta_ctasxcobrar.pdf"
   //local pIter := gtk_tree_iter_new() // Iterador para recorrer las filas
   local lValid := .F.,aLine
   
   
  // Obtener datos del modelo
 
   //aData := oModCxc:GetData()
   
//   view(aData)
   

   
   FERASE( cFilePDF )

   oPDF := TIMPRIMEPDF():New( cFilePDF )
   oPDF:PageSetSize( HPDF_PAGE_SIZE_LETTER, HPDF_PAGE_LANDSCAPE )

   // Título
   
      nY += 1
   oPDF:SetFont( "Helvetica-Bold", 10 )
   oPDF:CMSAY( nY, 20, "Empresa de Prueba" )
   nY += 0.4
   oPDF:CMSAY( nY, 20, "Rif: J000000000" )
   
   nY += 1
   oPDF:SetFont( "Helvetica-Bold", 14 )
   oPDF:CMSAY( nY, 8, "DETALLADO DE VENTAS" )
   oPDF:SetFont( "Helvetica-Bold", 9 )
   nY += 0.4
   /*
   oPDF:CMSAY( nY, 3, "Cliente:" )
   oPDF:CMSAY( nY, 10, "Tipo Doc:" )
   oPDF:CMSAY( nY, 17, "Documento:" )
   
   oPDF:SetFont( "Helvetica", 9 )
   oPDF:CMSAY( nY, 5, iif(Empty(cCliente)," Todos",cCliente) )
   oPDF:CMSAY( nY, 12, iif(Empty(cDocumento)," Todos",cDocumento) )
   //oPDF:CMSAY( nY, 19, iif(Empty(cNro)," Todos",cNro) )
   */

   
   //oPDF:CMSAY( nY, 20, "Al" )
   
   nY += 1.5

   // Encabezado
   oPDF:SetFont( "Helvetica-Bold", 9 )
   oPDF:CMSAY( nY, 1, "Fecha" )
   oPDF:CMSAY( nY, 3, "Hora" )
   oPDF:CMSAY( nY, 6, "Cliente" )
   oPDF:CMSAY( nY, 10.5, "Serie" )
   oPDF:CMSAY( nY, 12.8, "Control" )
   oPDF:CMSAY( nY, 15, "Numero" )
   oPDF:CMSAY( nY, 17, "Tipo Doc." )
   oPDF:CMSAY( nY, 20, "Total Doc." )
   oPDF:CMSAY( nY, 22.5, "TC" )
   

   nY += 0.5

   // Detalle
   oPDF:SetFont( "Courier", 8)
   
   
   FOR EACH aLine IN aData
      oPDF:CMSAY( nY, 1, DTOC(aLine[1]) )   // Fecha.
      oPDF:CMSAY( nY, 3, aLine[2] )   // Hora
	  oPDF:CMSAY( nY, 6, LEFT(aLine[4],30) )   // Cliente
	  oPDF:CMSAY( nY, 11, LEFT(aLine[5],12) )   // Serie
	
	  oPDF:CMSAY( nY, 13, STRZERO(aLine[6],8) )   // Contrl
	  oPDF:CMSAY( nY, 15,  STRZERO(VAL(aLine[7]),8)  )   // Numero
	  oPDF:CMSAY( nY, 17,   (aLine[8]) )   // Tipo Doc.
	  
	    
	  oPDF:CMSAY( nY, 18.9,   TRANSFORM(aLine[10], "@E 9,999,999.99") )   // Total Doc.
	  oPDF:CMSAY( nY, 21,   TRANSFORM(aLine[11], "@E 999,999.99") )   // Tasa
     // nTotMto += aLine[11]
	 // nTotApli += aLine[13]
	 
	  nTotSal += aLine[10]
      nY += 0.35
	  
   NEXT
   

   
   
   // Total
   nY += 0.5
   oPDF:SetFont( "Helvetica-Bold", 10 )
   oPDF:CMSAY( nY, 10, "TOTALES:" )
  // oPDF:CMSAY( nY, 19, TRANSFORM(nTotMto, "@E 9,999,999.99") )
  // oPDF:CMSAY( nY, 21.7, TRANSFORM(nTotApli, "@E 9,999,999.99") )
   oPDF:CMSAY( nY, 19.1, TRANSFORM(nTotSal, "@E 9,999,999.99") )

  // oPDF:Save()
   oPDF:End()

// Abrir
   #ifdef __PLATFORM__WINDOWS
      //hb_run( "start " + cFilePDF )
      WAPI_ShellExecute(0,"open",CurDrive()+":\"+CurDir()+"\"+cFilePDF,0) 
   #else
      hb_run( "xdg-open " + cFilePDF )
   #endif
   
   
return

//eof
