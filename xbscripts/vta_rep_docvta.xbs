/* vta_rep_docvta.xbs
 *
 * Formulario para consultar Cuentas por Cobrar en Fiscalius
 * Usa método CxCxFlujo() del servidor
 * Archivo de recursos: vta_rep_docvta.ui
 *
 */

#include "tpy_xbs.ch"
#include "harupdf.ch"
#include "tutilpdf.ch"

procedure vta_rep_docvta( oFormParent, oWndParent, oEntParent )
   local oForm 
   local oCxcWnd, oRes
   local oImgBanner, oImgLogo
   local rVentas, oCxc, oModCxc, oLBoxCxc
   local oBtnBuscar, oBtnSalir, oBtnVerDetalle
   local cEntCliente, cEntDocumento, oEntCliente, oEntDocumento,lActivo:=.T.
   local cEntFechaDesde, cEntFechaHasta
   local oEntFechaDesde, oEntFechaHasta
   
   SET PUBLIC oForm

   // Obtener rVentas directamente de oFormParent
   // oFormParent debería tener oGEmpresa
   rVentas := oFormParent:oGEmpresa:SetModulo("Ventas")

   // Verificar que rVentas no sea nil
   if hb_isNIL(rVentas)
      MsgStop("No se pudo acceder al módulo de Ventas")
      return
   endif

   // Guardar en variable pública para usar en callbacks
   ::rVentas := rVentas

   SET RESOURCES oRes FROM FILE oTPuy:cResources+"vta_rep_docvta.ui"

   DEFINE WINDOW oCxcWnd ;
          TITLE "Fiscalius. Reporte Detallado de Ventas" ;
          SIZE 1000,600 ;
          ID "window1" RESOURCE oRes

   DEFINE IMAGE oImgBanner ID "img_banner" RESOURCE oRes
   oImgBanner:Adjust(1000)

   DEFINE IMAGE oImgLogo ;
          FILE oTPuy:cImages+"fiscalius_logo_02.png";
          ID "img_logo" RESOURCE oRes
          oImgLogo:Adjust(60)

   // Campos de filtro del UI
   
  DEFINE ENTRY TYPE DATE oEntFechaDesde VAR cEntFechaDesde CALENDAR ;
          VALID .T. ;
          ID "ent_fecha_desde" RESOURCE oRes

   DEFINE ENTRY TYPE DATE oEntFechaHasta VAR cEntFechaHasta CALENDAR ;
          ID "ent_fecha_hasta" RESOURCE oRes
          
   DEFINE ENTRY oEntCliente VAR cEntCliente ;
          ID "ent_cliente" RESOURCE oRes

   DEFINE ENTRY oEntDocumento VAR cEntDocumento ;
          ID "ent_documento" RESOURCE oRes

		  
    DEFINE CHECKBOX oChkActivo VAR lActivo ID "chk_pdf" RESOURCE oRes

    // Botones del UI
    DEFINE BUTTON oBtnBuscar ;
           ACTION __CxcBuscar( oForm, oCxcWnd, oModCxc, oLBoxCxc, ;
                              oEntCliente, oEntDocumento, oEntFechaDesde,oEntFechaHasta,lActivo ) ;
           ID "btn_buscar" RESOURCE oRes
	
		   

   DEFINE BUTTON oBtnSalir ;
          ACTION oCxcWnd:End() ;
          ID "btn_salir" RESOURCE oRes

   // Box para el listbox
   DEFINE BOX oBoxData ID "box_data" RESOURCE oRes EXPAND FILL

   // Cargar datos iniciales (CxC pendientes)
   oCxc := rVentas:DocumentosVenta()

   if hb_isNIL( oCxc )
      MsgStop("No hay datos de Cuentas por Cobrar disponibles")
      return
   endif

   DEFINE MODEL oModCxc ;
          STRUCT oCxc:Struct() ;
          DATA   oCxc:GetData()

   DEFINE LISTBOX oLBoxCxc ;
          MODEL oModCxc ;
          OF oBoxData

   oLBoxCxc:lBar := .F.

   oLBoxCxc:bEdit := {||.t.}
   
   

   // Ocultar columnas técnicas
  // oLBoxCxc:SetColVisible( 1, .F. )    // empresa_id
   oLBoxCxc:SetColVisible( 3, .F. )    // cliente_id
   oLBoxCxc:SetColVisible( 9, .F. )    // Base
   oLBoxCxc:SetColVisible( 12, .F. )    // imp pvp
   oLBoxCxc:SetColVisible( 13, .F. )    // imp prod
   
   // Títulos de columnas
   oLBoxCxc:SetColTitle( 1, "Fecha." )
   oLBoxCxc:SetColTitle( 2, "Hora" )
   oLBoxCxc:SetColTitle( 4, "Cliente" )
   oLBoxCxc:SetColTitle( 5, "Serie" )
   oLBoxCxc:SetColTitle( 6, "Control" )
   oLBoxCxc:SetColTitle( 7, "Numero" )
   oLBoxCxc:SetColTitle( 8, "Tipo Doc." )
   oLBoxCxc:SetColTitle( 10, "Total Doc." )
   oLBoxCxc:SetColTitle( 11, "Tasa Cambio" )
  oLBoxCxc:Active()

   ACTIVATE WINDOW oCxcWnd MODAL

return



procedure __CxcBuscar( oForm, oWnd, oModel, oList, oEntCliente, oEntDocumento, oEntFechaDesde,oEntFechaHasta,lActivo )


   local hParam := hb_hash()
   local oCxc, aData
   local cCliente, cDocumento
   local aLine, aIter := ARRAY( 31 )  // 31 columnas según CxCxFlujo
   local rVentas

   // Obtener rVentas desde oForm
   rVentas := oForm:rVentas

   // Obtener valores de los campos de filtro
   cCliente   := alltrim( oEntCliente:GetText() )
   cDocumento := alltrim( oEntDocumento:GetText() )
   cFechaDesde := alltrim( oEntFechaDesde:GetText() )
   cFechaHasta := alltrim( oEntFechaHasta:GetText() )
  // lActivo       :=  oChkActivo:Value() 
  // view (lactivo)
   
   // Construir parámetros
   if !empty( cCliente )
      hParam[ "cliente" ] := cCliente
   endif

   if !empty( cDocumento )
      hParam[ "tipo_id" ] := cDocumento
   endif

  if !empty( cFechaDesde )
      hParam[ "fecha_desde" ] := cFechaDesde
   endif

   if !empty( cFechaHasta )
      hParam[ "fecha_hasta" ] := cFechaHasta
   endif

  // Por defecto mostrar solo pendientes
   hParam[ "estado" ] := "P"


   oCxc := rVentas:DocumentosVenta( hParam )

   if !hb_isObject( oCxc )
      MsgStop( "No hay información al respecto", "Lo siento.." )
      return
   endif


   if !hb_isNIL( oCxc )
      // Limpiar modelo existente
      oModel:oTreeView:ClearModel(.t.)

      // Agregar datos al modelo
      aData := oCxc:GetData()
      //view(oCxc:GetData())
      FOR EACH aLine IN aData
         APPEND LIST_STORE oModel:oLbx ITER aIter ;
                VALUES dtoc(aLine[1]), aLine[2], hb_ntos(aLine[3]),aLine[4], aLine[5], hb_ntos(aLine[6]),;
                      hb_ntos(aLine[7]),aLine[8],hb_ntos(aLine[9]),TRANSFORM(aLine[10],P_92),;
                      TRANSFORM(aLine[11],P_92),hb_ntos(aLine[12]),hb_ntos(aLine[13])
      NEXT
	  
	  IF lActivo
	  __CxcGenerarPDF(aData,cCliente,cDocumento)
	   ENDIF
   endif
   
   


return


procedure __CxcVerDetalle( oWnd, rVentas, oModel, oList )
return
