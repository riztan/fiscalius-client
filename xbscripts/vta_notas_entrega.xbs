function __NEDocExit(oForm)
   if MsgNoYes("¿Realmente desea salir?")
      ::oTimer:End()
      oForm:Release()
      return .T.
   endif
 return .F.



function __NEDocValFecha( oForm, oEnt, dValPrevio )
   local lRes := .t.
   local rQry, dFchFactura, cFactura

    cFactura := ::oEntFacturaNro:GetValue()
    if !hb_isNIL( cFactura ) .and. !Empty(cFactura)
       dFchFactura := ::rVentas:Transacciones('F', cFactura ):fecha
       if CTOD( oEnt:getValue() ) < dFchFactura
          ::oEntFecha:SetValue( DTOC(dFchFactura) )
          ::oLabInfo:SetText( "La nota no puede tener fecha anterior a la factura." )
          oEnt:SetValue( DTOC(dFchFactura) )
          return .F.
       endif
    endif
   if CTOD( ::oEntVcmto:getValue() ) < CTOD( ::oEntFecha:getValue() )
      ::oEntVcmto:SetValue( ::oEntFecha:GetValue() )
   endif
   dValPrevio := CTOD( oEnt:getValue() )
   rQry := ::rEmpresa:GetTasa( dValPrevio ) 
   ::aDivisas := {}
   ::aMonedas := {}
   While !rQry:Eof()
      if rQry:codigo="USD"
         AADD( ::aDivisas, ALLTRIM(rQry:codigo)+" "+ hb_ntos( rQry:valor ) )
         AADD( ::aMonedas, rQry:moneda_id )
      endif
      rQry:Skip()
   EndDo
   if hb_isObject( ::oComboDivisa )
      ::oComboDivisa:RemoveAll()
      ::oComboDivisa:SetItems( ::aDivisas )
   endif
 return lRes





function __NECargarCondiciones( oForm )
   local rQryCond
   rQryCond := ::rVentas:Condiciones()
   ::aCondiciones := {}
   ::aCondicionesId := {}
   While !rQryCond:Eof()
      AADD( ::aCondiciones, ALLTRIM(rQryCond:nombre) )
      AADD( ::aCondicionesId, hb_ntos(rQryCond:id) )
      rQryCond:Skip()
   EndDo
   

      if hb_isObject( ::oComboCondicion ) .and. LEN( ::aCondiciones ) > 0
       if VALTYPE(::oComboCondicion:aItems)="A"
         ::oComboCondicion:RemoveAll()
       endif
         ::oComboCondicion:SetItems( ::aCondiciones )
      endif

   
return .T.



function __NECargarSeries( oForm )
   local rQrySeries
   
   rQrySeries := ::rEmpresa:SeriesFiscales(14)
   //view(rQrySeries)
   ::aSeries := {}
   ::aSeriesId := {}
   
   While !rQrySeries:Eof()
      AADD( ::aSeries, ALLTRIM(rQrySeries:serie_fiscal) )
      AADD( ::aSeriesId, hb_ntos(rQrySeries:id) )
      rQrySeries:Skip()
   EndDo
   
   if hb_isObject( ::oComboSerie )
    if VALTYPE(::oComboSerie:aItems)="A"
      ::oComboSerie:RemoveAll()
    endif
      ::oComboSerie:SetItems( ::aSeries )
   endif
   
return .T.

procedure __NEChangeEstado( oForm, lConfirm )
   if ::lSilence ; return ; endif
   if ::cComboEstado = "Anulada" .or. ::cComboEstado = "Cerrada"
      __NEDocsRefresh( oForm, lConfirm )
      if ::cPreEstado == "B" 
         __NESave( oForm )
      endif
   else
      __NEDocsRefresh( oForm, !lConfirm )
   endif
return



procedure __NEDetalRefresh( oForm )
   local aLine, aData, oErr
   local cFactura, dFchFactura

   if ::hDocumento["estado"] = "C"
      RETURN
   endif

   cFactura := ::oEntFacturaNro:GetValue()
   if !hb_isNIL( cFactura ) .and. !Empty(cFactura)
      dFchFactura := ::rVentas:Transacciones('F', cFactura ):fecha
      if CTOD(cFactura) > dFchFactura
         ::oEntFecha:SetValue( DTOC(dFchFactura) )
         ::oLabInfo:SetText( "Ajustada la fecha del documento." )
      endif
   endif

  // view(::rFactDetal:GetData())
   ::oModDetal:oTreeView:ClearModel(.t.)
   aData := ::rFactDetal:GetData()
  // view(adata)
   if !Empty( aData )
      FOR EACH aLine IN aData
         TRY
            APPEND LIST_STORE ::oModDetal:oLbx ITER aIter ;
                   VALUES hb_ntos(aLine[1]), hb_ntos(aLine[2]), aLine[3], ;
                          aLine[4], hb_ntos(aLine[5]),;
                          hb_ntos(aLine[6]),  hb_ntos(aLine[7]), ;
                          hb_ntos(aLine[8]),  hb_ntos(aLine[9]), ; 
                          hb_ntos(aLine[10]), hb_ntos(aLine[11]),; 
                          hb_ntos(aLine[12]), aLine[13], ;
                          aLine[14], aLine[15], ;
                          aLine[16], ;
                          hb_ntos(aLine[17]), ;
                          aLine[18], ;
                          aLine[19], ;
                          hb_ntos(aLine[20]), ;
                          hb_ntos(aLine[21]), ;
                          hb_ntos(iif(aLine[5]>0, ROUND(aLine[21]/aLine[5],2), 0)),;
                          hb_ntos(aLine[5]),;
                           hb_ntos(aLine[22]), ;
                          hb_ntos(iif(aLine[5]>0, ROUND(aLine[22]/aLine[5],2), 0))
         CATCH oErr
            View( "__NEDetalRefresh(): " + oErr:Description )
         END
      NEXT
      __NECalcula(oForm)
   endif
return



procedure __vtaNotaEntrega( oForm, oFormParent, oBoxFactura, oModel, lNew )
   local lPreConfirm := ::lConfirm
   local hMontos := hb_hash()
   local aData, aLine, nLen, aVal, aTemp
   local oCol,aBox

   default lNew := .T.
   ::lSilence := .t.
   ::oNotaWnd:Maximize()
   ::lNew := lNew

   if ::lNew 
      ::lLoad      := .F.
      ::lSave      := .F.
      ::rDocumento := ::rVentas:Documento( ::cTipoDocumento ,'')
      ::hDocumento := ::rDocumento:Data()
      ::rFactDetal := ::rDocumento:Detal()
      ::cFecha := DTOC( DATE() )
      ::oLabNumero:SetValue( "00000000" )
      ::oLabNroControl:SetValue( "00000000" )
      ::oEntCli:SetValue( "" )
      ::oEntFecha:SetValue( DTOC(DATE()) )
      ::oEntVcmto:SetValue( DTOC(DATE()) )
      ::oEntFacturaNro:SetValue("")
      ::oEntIvaE:SetValue( "0" )
      ::oEntIvaR:SetValue( "0" )
      ::oEntIvaG:SetValue( "0" )
      ::oEntIvaS:SetValue( "0" )
      ::oEntOtrImp:SetValue( "0" )
      ::oEntImpProd:SetValue( "0" )
      ::oEntMonBase:SetValue( "0" )
      ::oComboEstado:SetValue("Borrador", .F. ) 
      ::cComboEstado := "B"
      ::cPreEstado   := ::cComboEstado
      ::oEntTotal:SetValue( "0" )
      if hb_isObject( ::oModDetal ) 
         ::oModDetal:oTreeView:ClearModel(.t.)
      endif
   else
      ::lLoad      := .T.
      ::lSave      := .F.
      ::rDocumento := ::rVentas:Documento( ::cTipoDocumento, oModel:GetCol("numero") )
      ::hDocumento := ::rDocumento:Data()
      ::rFactDetal := ::rDocumento:Detal()
      ::cFecha := DTOC( ::hDocumento["fecha"] )
      ::oLabNumero:SetValue( oModel:GetCol("numero") )
      ::oLabNroControl:SetValue( ::hDocumento["numero_control"] )
      ::oEntCli:SetValue( oModel:GetCol("Cliente") )
      ::cCodCli := oModel:GetCol("cliente_id")
      ::cCondicionId := oModel:GetCol(::hCol["condicion_id"])
      ::cCondicion :=  oModel:GetCol(::hCol["condicion_nombre"])
      ::cSerieId := oModel:GetCol(::hCol["serie_id"])
      ::cSerie :=  oModel:GetCol(::hCol["serie_fiscal"])
      
      //view(::cSerieId)
      
      // Actualizar el combo para mostrar la condicion seleccionada
      
         if hb_isObject( ::oComboCondicion ) .and. !empty( ::aCondiciones )
             ::oComboCondicion:SetValue( ::cCondicion )
         endif
          
 		 
          if hb_isObject( ::oComboSerie ) .and. !empty( ::aSeries )
             ::oComboSerie:SetValue( ::cSerie )
          endif
        
      
      ::cCodVendedor := oModel:GetCol("vendedor_id")
      ::oEntFecha:SetValue( oModel:GetCol("fecha") )
      ::oEntVcmto:SetValue( oModel:GetCol(5) )
      ::oEntFacturaNro:SetValue( ALLTRIM(::hDocumento["doc_referencia_id"]) )
      ::oEntIvaE:SetValue( "0" )
      ::oEntIvaR:SetValue( "0" )
      ::oEntIvaG:SetValue( "0" )
      ::oEntIvaS:SetValue( "0" )
// Usar otros_imp e imp_prod desde el servidor si existe, sino inicializar en 0
       if hb_hHasKey( ::hDocumento, "otros_imp" ) .and. hb_hHasKey( ::hDocumento, "imp_prod" )
 			::oEntOtrImp:SetValue( TRANSFORM( ::hDocumento["otros_imp"], P_92 ) )        
             ::oEntImpProd:SetValue( TRANSFORM( ::hDocumento["imp_prod"], P_92 ) )
       else
           ::oEntOtrImp:SetValue( "0" )
           ::oEntImpProd:SetValue( "0" )
       endif
      
      ::oEntMonBase:SetValue( hb_ntos(::hDocumento["monto_base"]) )
      ::oEntTotal:SetValue( hb_ntos(::hDocumento["monto_total"]) )
      ::lConfirm := .F.
      do case
      case ::hDocumento["estado"] = "B"
         ::oComboEstado:SetValue( "Borrador" )
      case ::hDocumento["estado"] = "A"
         ::oComboEstado:SetValue( "Anulada"  )
      case ::hDocumento["estado"] = "C"
         ::oComboEstado:SetValue( "Cerrada"  )
      endcase
      ::cPreEstado := ::hDocumento["estado"]
      ::lConfirm := lPreconfirm
   endif

   __NEDocValFecha( oForm, ::oEntFecha, @::cPFecha )

if !::lNew
      aData := {}
      FOR EACH aLine IN ::rFactDetal:GetData()
         // Verificar longitud antes de acceder
         nLen := LEN( aLine )
         AADD( aData, {hb_ntos(aLine[1]), hb_ntos(aLine[2]), aLine[3], ;
                       aLine[4], hb_ntos(aLine[5]),;
                       hb_ntos(aLine[6]),  hb_ntos(aLine[7]), ;
                       hb_ntos(aLine[8]),  hb_ntos(aLine[9]), ; 
                       hb_ntos(aLine[10]), hb_ntos(aLine[11]),; 
                       hb_ntos(aLine[12]), aLine[13], ;
                       aLine[14], aLine[15], ;
                       aLine[16], ;
                       hb_ntos(aLine[17]), ;
                       aLine[18], ;
                       aLine[19], ;
                       hb_ntos(aLine[20]), ;
                       hb_ntos(iif(nLen >= 21, aLine[21], 0)), ;
                       hb_ntos(iif(nLen >= 21 .and. aLine[5]>0, ROUND(aLine[21]/aLine[5],2), 0)),;
                       hb_ntos(aLine[5]),;
                       hb_ntos(iif(nLen >= 22, aLine[22], 0)), ;
                       hb_ntos(iif(nLen >= 22 .and. aLine[5]>0, ROUND(aLine[22]/aLine[5],2), 0))})
      NEXT
   else
      aData := {{0,0,'','',0,0,0,0,0,0,0,'','','',date(),0,0,'','',0,0,0,0,0,0}}
   endif

   if !hb_isObject( ::oModDetal )
DEFINE MODEL   ::oModDetal           ;
              STRUCT  {{"detalle_id",     "N",10, 0},;
                      {"documento" ,     "N",10, 0},;
                      {"codigo_local",   "C",20, 0},;
                      {"descripcion",    "C",100,0},;
                      {"cantidad",       "N",10, 0},;
                      {"precio_unitario","N",13, 2},;
                      {"descuento",      "N",13, 2},;
                      {"subtotal",       "N",13, 2},;
                      {"iva_porcentaje", "N",04, 2},;
                      {"iva_monto",      "N",04, 2},;
                      {"total",          "N",13, 2},;
                      {"nombre_global",  "C",100,0},;
                      {"tipo_inventario","C",01, 0},;
                      {"lote",           "C",10, 0},;
                      {"fecha_vcmto",    "D",10, 0},;
                      {"id_ubicacion",   "N",10, 0},;
                      {"almacen_id",     "N",10, 0},;
                      {"nombre_almacen", "C",20, 0},;
                      {"detalles_json",  "C",100,0},;
                      {"item",           "N",10, 0},;
                      {"imp_pvp",        "N",13, 2},;
                      {"imp_pvp_unit",   "N",13, 2},;
                     {"cant_maxima",    "N",10, 2},;
                     {"imp_produccion", "N",13, 2},;
                     {"imp_prod_unit",  "N",13, 2};
                     } ;
              DATA   aData
      DEFINE LISTBOX ::oLBoxDetal ;
             MODEL   ::oModDetal  ;
             OF      ::oBoxDetalles
      ::oLBoxDetal:lBar  := .f.
      ::oLBoxDetal:bNew  := {|| __NEAddDetal( oForm ) }
      ::oLBoxDetal:bEdit := {|| .T. }
      ::oLBoxDetal:bDel  := {|| __NEDelDetal( oForm ) }
      ::oLBoxDetal:SetColVisible( 01, .f. )
      ::oLBoxDetal:SetColVisible( 02, .f. )
      
      
      ::oLBoxDetal:SetColVisible( 12, .f. )     //- Nombre Global
      ::oLBoxDetal:SetColVisible( 13, .f. )     //- Tipo de Inventario
      ::oLBoxDetal:SetColVisible( 14, .f. )     //- Lote
      ::oLBoxDetal:SetColVisible( 15, .f. )     //- Vencimiento
      ::oLBoxDetal:SetColVisible( 16, .f. )     //- Ubicación
      ::oLBoxDetal:SetColVisible( 17, .f. )     //- Almacen Id
      ::oLBoxDetal:SetColVisible( 18, .f. )     //- Almacen Nombre
      ::oLBoxDetal:SetColVisible( 19, .f. )     //- Detalles (JSON)
      ::oLBoxDetal:SetColVisible( 20, .f. )     //- Item
      ::oLBoxDetal:SetColVisible( 23, .f. )     //- cant maxima
      
      ::oLBoxDetal:SetColTitle( 03, "Código" )
      ::oLBoxDetal:SetColTitle( 04, "Descripción" )
      ::oLBoxDetal:SetColTitle( 05, "Cantidad" )
      ::oLBoxDetal:SetColTitle( 06, "Precio" )
      ::oLBoxDetal:SetColTitle( 07, "Descuento" )
      ::oLBoxDetal:SetColTitle( 08, "SubTotal" )
      ::oLBoxDetal:SetColTitle( 09, "IVA (%)" )
      ::oLBoxDetal:SetColTitle( 10, "IVA (Monto)" )
      ::oLBoxDetal:SetColTitle( 11, "Total" )
      ::oLBoxDetal:SetColTitle( 21, "Imp.PVP" )
      ::oLBoxDetal:SetColTitle( 22, "Imp.PVP Unit" )
      ::oLBoxDetal:SetColTitle( 23, "Cant Máxima" )
      ::oLBoxDetal:SetColTitle( 24, "Imp Prod. Total" )     //-- Columna Imp Prod. Total Linea
      ::oLBoxDetal:SetColTitle( 25, "Imp Prod. Unit" )   //-- Columna Imp Prod. Total Linea
	  //::oLBoxDetal:SetColTitle( 23, "Capacidad" )   //-- Columna 
      ::oLBoxDetal:Active()
   else
      ::oModDetal:oTreeView:ClearModel(.t.)
if !Empty( aData )
         FOR EACH aLine IN aData
            TRY
               nLen := Len( aLine )
               aVal := {}
               AADD( aVal, iif(nLen>=1, aLine[1], "0") )
               AADD( aVal, iif(nLen>=2, aLine[2], "0") )
               AADD( aVal, iif(nLen>=3, aLine[3], "") )
               AADD( aVal, iif(nLen>=4, aLine[4], "") )
               AADD( aVal, iif(nLen>=5, aLine[5], "0") )
               AADD( aVal, iif(nLen>=6, aLine[6], "0") )
               AADD( aVal, iif(nLen>=7, aLine[7], "0") )
               AADD( aVal, iif(nLen>=8, aLine[8], "0") )
               AADD( aVal, iif(nLen>=9, aLine[9], "0") )
               AADD( aVal, iif(nLen>=10, aLine[10], "0") )
               AADD( aVal, iif(nLen>=11, aLine[11], "0") )
               AADD( aVal, iif(nLen>=12, aLine[12], "0") )
               AADD( aVal, iif(nLen>=13, aLine[13], "") )
               AADD( aVal, iif(nLen>=14, aLine[14], "") )
               AADD( aVal, iif(nLen>=15, aLine[15], "") )
               AADD( aVal, iif(nLen>=16, aLine[16], "") )
               AADD( aVal, iif(nLen>=17, aLine[17], "0") )
               AADD( aVal, iif(nLen>=18, aLine[18], "0") )
               AADD( aVal, iif(nLen>=19, aLine[19], "") )
               AADD( aVal, iif(nLen>=20, aLine[20], "0") )
               AADD( aVal, iif(nLen>=21, aLine[21], "0") )
               AADD( aVal, iif(nLen>=22, aLine[22], "0") )
               AADD( aVal, iif(nLen>=23, aLine[23], "0") )
               AADD( aVal, iif(nLen>=24, aLine[24], "0") )
               AADD( aVal, iif(nLen>=25, aLine[25], "0") )
               APPEND LIST_STORE ::oModDetal:oLbx ITER aIter VALUES aVal[1], aVal[2], aVal[3], aVal[4], aVal[5], aVal[6], aVal[7], aVal[8], aVal[9], aVal[10], aVal[11], aVal[12], aVal[13], aVal[14], aVal[15], aVal[16], aVal[17], aVal[18], aVal[19], aVal[20], aVal[21], aVal[22], aVal[23]
            CATCH oErr
               View( "__vtaNotaEntrega: " + oErr:Description )
            END
         NEXT
      endif
   endif

   ::oModDetal:oTreeView:bRow_Activated := nil
   #define __NECODIGO   3
   oCol := ::oModDetal:aCol[__NECODIGO]
   oCol:oRenderer:SetEditable( .T. )
   oCol:oRenderer:bEdited := {|oSender, path, uVal, aIter|;
                               __NEEditInv( oForm, oSender, path, uVal, ::oModDetal:aIter,;
                                          ::oModDetal:oLbx, ::oModDetal:oTreeView, __NECODIGO )  }
   oCol:oRenderer:SetColumn( oCol )

   
   
   
   
   
   
   
   
   
   
   
   #define __NECANTIDAD   5
   oCol := ::oModDetal:aCol[__NECANTIDAD]
   oCol:oRenderer:SetEditable( .T. )
   oCol:oRenderer:bEdited := {|oSender, path, uVal, aIter|;
                               __NEEditInv( oForm, oSender, path, uVal, ::oModDetal:aIter,;
                                          ::oModDetal:oLbx, ::oModDetal:oTreeView, __NECANTIDAD )  }
   oCol:oRenderer:SetColumn( oCol )

   #define __NEPRECIO   6
   oCol := ::oModDetal:aCol[__NEPRECIO]
   oCol:oRenderer:SetEditable( .T. )
   oCol:oRenderer:bEdited := {|oSender, path, uVal, aIter|;
                               __NEEditInv( oForm, oSender, path, uVal, ::oModDetal:aIter,;
                                          ::oModDetal:oLbx, ::oModDetal:oTreeView, __NEPRECIO )  }
   oCol:oRenderer:SetColumn( oCol )

   #define __NEDESCUENTO   7
   oCol := ::oModDetal:aCol[__NEDESCUENTO]
   oCol:oRenderer:SetEditable( .T. )
   oCol:oRenderer:bEdited := {|oSender, path, uVal, aIter|;
                               __NEEditInv( oForm, oSender, path, uVal, ::oModDetal:aIter,;
                                          ::oModDetal:oLbx, ::oModDetal:oTreeView, __NEDESCUENTO )  }
   oCol:oRenderer:SetColumn( oCol )

   #define __NESUBTOTAL      8
   #define __NEIVAPORCEN     9
   #define __NEIVAMONTO     10
   #define __NETOTAL        11

   ::oEntMonBase:SetValue("0")
   ::bDetalCode := {|oTView, pModel, aIter| __NECalMontos( oTView, pModel, aIter, oForm ) }
   ::oLBoxDetal:ForEach( ::bDetalCode )
   __NEDocsRefresh( oForm, .F. )
   __NECalcula(oForm)
   FOR EACH aBox IN { {::oBoxIvaExe, ::oEntIvaE}, ;
                      {::oBoxIvaRed, ::oEntIvaR}, ;
                      {::oBoxIvaGen, ::oEntIvaG}, ;
                      {::oBoxIvaSun, ::oEntIvaS}, ;
                      {::oBoxOtrImp, ::oEntOtrImp},;
                      {::oBoxImpProd, ::oEntImpProd} }
      if ToNum( aBox[2]:GetValue() ) = 0
         aBox[1]:Hide()
      else
         aBox[1]:Show()
      endif
   NEXT

   oBoxFactura:Show()
   ::lSilence := .f.
return



procedure __NEEditInv( oForm, oSender, cPath, uVal, aIter, oModel, oTreeView, nCol )
   local pNextCol, pPath, uPrevio
   local nCantNueva, nCantMax

   if ::cComboEstado = "Anulada" .or. ::cComboEstado = "Cerrada" 
      return 
   endif
   if empty( uVal ) ; return ; endif

   if nCol=__NECODIGO
      __NESetValue( oTreeView, oModel, aIter, nCol, uVal )
      return
   endif

   if Empty( oTreeView:GetAutoValue( __NECODIGO ) )
      oTreeView:SetPosCol( aIter, __NECODIGO, .f. )
      return
   endif

if nCol=__NECANTIDAD
       nCantNueva := ToNum( uVal )
       nCantMax := ToNum( oTreeView:GetAutoValue( 23 ) )  // columna 23 = cant_maxima
       if nCantMax > 0 .and. nCantNueva > nCantMax
          ::oLabInfo:SetText( "Cantidad no puede exceder la de factura (" + hb_ntos(nCantMax) + ")" )
          return
       endif
      __NESetValue( oTreeView, oModel, aIter, nCol, uVal )
      __NECalcula( oForm )
      oTreeView:SetPosCol( aIter, __NEPRECIO, .f. )
      return
   endif

   if nCol=__NEPRECIO
      __NESetValue( oTreeView, oModel, aIter, nCol, uVal )
      __NECalcula( oForm )
      oTreeView:SetPosCol( aIter, __NEDESCUENTO, .f. )
      return
   endif

   if nCol=__NEDESCUENTO
      __NESetValue( oTreeView, oModel, aIter, nCol, uVal )
      __NECalcula( oForm )
      oTreeView:SetPosCol( aIter, __NETOTAL, .f. )
      return
   endif
return




procedure __NESetValue( oTreeView, oModel, aIter, nCol, uValue  )
   local nMonto, nDescuento, nIvaPorcen, nIvaMonto:= 0

   if oTreeView:IsGetSelected( aIter )
      if nCol= __NECANTIDAD .or. nCol= __NEPRECIO .or. nCol= __NEDESCUENTO
         if nCol = __NEDESCUENTO
            nDescuento := VAL(uValue)
            nMonto := (ToNum( oTreeView:GetAutoValue(__NECANTIDAD, aIter) ) * ToNum( oTreeView:GetAutoValue(__NEPRECIO, aIter))) - nDescuento
         else
            nDescuento := VAL( oTreeView:GetAutoValue(__NEDESCUENTO, aIter) )
         endif
         if nCol = __NECANTIDAD 
            nMonto := (VAL(uValue) * ToNum( oTreeView:GetAutoValue(__NEPRECIO, aIter))) - nDescuento
         elseif nCol = __NEPRECIO
            nMonto := (ToNum( oTreeView:GetAutoValue(__NECANTIDAD, aIter) ) * VAL(uValue)) - nDescuento
         endif
         nMonto := ROUND( nMonto, 2 )
         oModel:Set( aIter, __NESUBTOTAL, STR( nMonto ) )
         nIvaPorcen := ToNum( oTreeView:GetAutoValue(__NEIVAPORCEN, aIter) )
         if nIvaPorcen > 0
            nIvaMonto := ROUND( nMonto * (nIvaPorcen / 100), 2 )
            oModel:Set( aIter, __NEIVAMONTO, STR(nIvaMonto) )
         endif
         oModel:Set( aIter, __NETOTAL, STR( ROUND( nMonto + nIvaMonto ,2 ) ) )
         uValue := STR( VAL(uValue) )
      endif
      oModel:Set( aIter, nCol, uValue )
   endif
return



procedure __NECalcula( oForm )
   local nOtrosImp := 0, aTasa

   ::oEntTotal:SetValue("0")
   ::oEntMonBase:SetValue("0")
   ::oEntIvaE:SetValue("0")
   ::oEntIvaR:SetValue("0")
   ::oEntIvaG:SetValue("0")
   ::oEntIvaS:SetValue("0")
   ::oEntOtrImp:SetValue("0")
   ::oEntImpProd:SetValue("0") // Initialize imp_prod 
   ::hDocumento["iva"] := {=>}
   ::bDetalCode := {|oTView, pModel, aIter| __NECalMontos( oTView, pModel, aIter, oForm ) }
   if !hb_isObject( ::oLBoxDetal )
      return
   endif
   ::oLBoxDetal:ForEach( ::bDetalCode )












return



procedure __NECalMontos( oTView, pModel, aIter, oForm )
     local nBase, nMonto, nTotal, cIva, nPorcentaje , nImpPvp:=0, nImpProduccion:=0, nOtrImp:=0,nImpProd:=0,aBox

   nPorcentaje := ToNum( oTView:GetAutoValue( __NEIVAPORCEN, aIter ) )
   
   if nPorcentaje > 0
      nMonto := ToNum( oTView:GetAutoValue( __NESUBTOTAL, aIter ) )
      nBase  := ToNum( ::oEntMonBase:GetValue() )
      nOtrImp:= ToNum( ::oEntOtrImp:GetValue())
      nImpProd:= ToNum( ::oEntImpProd:GetValue())
      nTotal := ROUND( nBase+nMonto, 2 )
      ::oEntMonBase:SetValue( TRANSFORM( nTotal, P_92 ) )
   endif

    // Calculate imp_pvp
   nImpPvp := ROUND( ToNum( oTView:GetAutoValue( 22, aIter ) ) * ToNum( oTView:GetAutoValue( __NECANTIDAD, aIter ) ), 2 ) // imp_pvp * cantidad
   nImpProduccion := ROUND( ToNum( oTView:GetAutoValue( 25, aIter ) ) * ToNum( oTView:GetAutoValue( __NECANTIDAD, aIter ) ), 2 ) // imp_produccion * cantidad
//   oTView:Set( aIter, 21, TRANSFORM( nImpPvp, P_92 ) )
   nOtrImp += nImpPvp
   nImpProd += nImpProduccion
   if nPorcentaje = 0
      nMonto := ToNum( oTView:GetAutoValue( __NESUBTOTAL, aIter ) )
      nTotal := ROUND( nMonto, 2 )
      ::oEntMonBase:SetValue( TRANSFORM( nTotal, P_92 ) )
      ::oEntIvaE:SetValue( TRANSFORM( nTotal, P_92 ) )
      ::oEntMonBase:SetValue( TRANSFORM( nTotal, P_92 ) )
   endif

   if nPorcentaje > 0
      nMonto := ToNum( oTView:GetAutoValue( __NEIVAMONTO, aIter ) )
      if nPorcentaje = 8
         nBase  := ToNum( ::oEntIvaR:GetValue() )
         nTotal := ROUND( nBase + nMonto, 2 )
         ::oEntIvaR:SetValue( TRANSFORM( nTotal, P_92 ) )
      elseif nPorcentaje = 16
         nBase  := ToNum( ::oEntIvaG:GetValue() )
         nTotal := ROUND( nBase + nMonto, 2 )
         ::oEntIvaG:SetValue( TRANSFORM( nTotal, P_92 ) )
      elseif nPorcentaje = 31  // IVA Suntuario
         nBase  := ToNum( ::oEntIvaS:GetValue() )
         nTotal := ROUND( nBase + nMonto, 2 )
         ::oEntIvaS:SetValue( TRANSFORM( nTotal, P_92 ) )
      endif
   endif


nTotal := ROUND( ToNum( ::oEntMonBase:GetValue() ) +;
                     ToNum( ::oEntIvaR:GetValue() ) +;
                     ToNum( ::oEntIvaG:GetValue() ) +;
                     ToNum( ::oEntIvaS:GetValue() ) +;
                     nOtrImp + nImpProd, 2 ) // Include otros_imp + imp_prod
   ::oEntTotal:SetValue( TRANSFORM( nTotal, P_92 ) ) 

   ::oEntOtrImp:SetValue( TRANSFORM( nOtrImp, P_92 ) ) // Set otros_imp
   ::oEntImpProd:SetValue( TRANSFORM( nImpProd, P_92 ) ) // Set imp_prod

   FOR EACH aBox IN { {::oBoxIvaExe, ::oEntIvaE}, ;
                      {::oBoxIvaRed, ::oEntIvaR}, ;
                      {::oBoxIvaGen, ::oEntIvaG}, ;
                      {::oBoxIvaSun, ::oEntIvaS}, ;
                      {::oBoxOtrImp, ::oEntOtrImp},;
                      {::oBoxImpProd, ::oEntImpProd} }
      if ToNum( aBox[2]:GetValue() ) = 0
         aBox[1]:Hide()
      else
         aBox[1]:Show()
      endif
   NEXT
   
   

return



procedure __NEAddDetal( oForm )
   local aIter := ARRAY(4)
   local aLine := {'','','','','','','','','','','','','','','','','','','','','','','','',''}

   //-  ignoramos si el documento esta anulado o cerrado.
   if ::cComboEstado = "Anulada" .or. ::cComboEstado = "Cerrada" 
      return 
   endif

   APPEND LIST_STORE ::oModDetal:oLbx ITER aIter ;
          VALUES aLine[ 1], aLine[ 2], aLine[ 3],;
                 aLine[ 4], aLine[ 5], ;
                 aLine[ 6], aLine[ 7], ;
                 aLine[ 8], aLine[ 9], ; 
                 aLine[10], aLine[11], ; 
                 aLine[12], aLine[13], ;
                 aLine[14], aLine[15], ;
                 aLine[16], aLine[17], ;
                 aLine[18], aLine[19], ;
                 aLine[20], aLine[21], ;
                 aLine[22], aLine[23], ;
                 aLine[24],aLine[25]

   ::oModDetal:oTreeView:SetFocus()
   ::oModDetal:GoBottom()
   ::oModDetal:oTreeView:SetPosCol( aIter, __NECODIGO, .T. )
return




procedure __NEDocsRefresh( oForm, lConfirm )
   default lConfirm := .F.
   if lConfirm
      if !MsgNoYes( "¿Confirma el cambio de estado del documento?" )
         ::oComboEstado:setValue("Borrador")
      endif
   endif
   ::oEntIvaE:SetEditable( .F. )
   ::oEntIvaR:SetEditable( .F. )
   ::oEntIvaG:SetEditable( .F. )
   ::oEntIvaS:SetEditable( .F. )
   ::oEntMonBase:SetEditable( .F. )

   if (::hDocumento["estado"] = "A" .or. ::hDocumento["estado"] = "C") .or. ( ::cComboEstado = "A" .or. ::cComboEstado = "C" )
      ::oEntCli:Disable()
      ::oEntFecha:Disable()
      ::oEntVcmto:Disable()
      if ::hDocumento["estado"]="C"
         ::oBtnImprime:Enable() 
      endif
      if ::hDocumento["estado"]="A"
         ::oBtnImprime:Disable() 
      endif
      if ::lSave .or. ::lLoad
         ::oComboEstado:Disable()
      endif
   else
      ::oEntCli:Enable()
      ::oEntFecha:Enable()
      ::oEntVcmto:Enable()
      ::oBtnImprime:Disable() 
      if !::lSave
         ::oComboEstado:Enable()
      endif
   endif
return




procedure __NEDelDetal( oForm, lAll )
   local aIter := ARRAY(4)
   local pPath
   default lAll := .F.

   if ::hDocumento["estado"] = "C"
      RETURN
   endif
   if ::cComboEstado = "Anulada" .or. ::cComboEstado = "Cerrada" 
      return 
   endif
   if lAll
      if ::rDocumento:DelItem( ,.T. )
         ::oModDetal:oTreeView:ClearModel(.T.)
      endif
   endif
   if ::oModDetal:oTreeView:IsGetSelected( aIter ) 
      pPath := ::oModDetal:oTreeView:GetPath( aIter )
      if !Empty( ::oModDetal:oTreeView:GetAutoValue( 18 ) )
         if MsgNoYes( "¿Realmente desea eliminar este item?" )
            if !::rDocumento:DelItem( ALLTRIM( ::oModDetal:oTreeView:GetAutoValue( 18 ) ) )
               return 
            endif
         endif
      endif
      ::oModDetal:oLbx:Remove( aIter )
      gtk_tree_view_set_cursor( ::oModDetal:oTreeView:pWidget, pPath )
   endif
   __NECalcula( oForm )
return



Procedure __NESave( oForm, oFormParent )

   local bSaveDetal, uResp, aIter := ARRAY( 4 ), nIdx:=0
   local hCorrel, lDetal

  
   if (::cComboEstado = "Anulada" .or. ::cComboEstado = "Cerrada") .and. !( ::cPreEstado = "B" )
       __NECalcula( oForm )
       MsgAlert( "Este documento no puede ser alterado.", "Atención" )
       return 
   endif
   
 

   ::hDocumento["cliente_id"       ] := ::cCodCli
   ::hDocumento["vendedor_id"      ] := ::cCodVendedor
   ::hDocumento["doc_referencia_id"] := ::cFacturaNro
   ::hDocumento["fecha"            ] := CTOD(::oEntFecha:GetValue())
   ::hDocumento["fecha_vencimiento"] := CTOD(::oEntVcmto:GetValue())
  // ::hDocumento["condicion_id"     ] := '1'
   ::hDocumento["monto_base"       ] := ::oEntMonBase:GetValue()
   ::hDocumento["monto_total"      ] := ::oEntTotal:GetValue()
   ::hDocumento["otros_imp"        ] := ::oEntOtrImp:GetValue()      // Otros Impuestos
   ::hDocumento["imp_prod"        ] := ::oEntImpProd:GetValue()      // Impuesto Produccion
   //endif
   ::hDocumento["estado"           ] := LEFT( ::oComboEstado:GetValue(), 1 )

nIdx := ASCAN( ::aCondiciones, {|x| ALLTRIM(x) == ALLTRIM(::cCondicion)} )
   ::hDocumento["condicion_id"]        := iif(nIdx > 0, ::aCondicionesId[nIdx], 0)

   nIdx := ASCAN( ::aSeries, {|x| ALLTRIM(x) == ALLTRIM(::cSerie)} )
   ::hDocumento["serie_id"]        := iif(nIdx > 0, ::aSeriesId[nIdx], 0)
   ::cSerieID:=::hDocumento["serie_id"]
   hCorrel := ::rVentas:ValidarCorrelativo( ::cSerieId, 14 )	 
   if ::cComboEstado == "Cerrada"		
      if !hb_hHasKey(hCorrel, "disponible") .or. !hCorrel["disponible"]
         MsgStop( hCorrel["mensaje"] + ". No se puede cerrar el documento.", "Error" )
         return
      endif
   endif


   uResp := ::rDocumento:SetData( ::hDocumento )
   if hb_isHash(uResp) .and. hb_hHasKey(uResp, "return") .and. !uResp["return"]
      ::oLabInfo:SetText( uResp["message"] )
      return
   endif
   
   //view(::hDocumento)
   //return

   bSaveDetal := {|oTView, pModel, aIter| __NESaveDetal( oTView, pModel, aIter, oForm )  }
   uResp := ::rDocumento:Save()
   if hb_isLogical( uResp ) .and. uResp
       ::hDocumento   := ::rDocumento:Data()
       ::aDetal := {}
       ::oLBoxDetal:ForEach( bSaveDetal )
       if !::rDocumento:SetDetal( ::aDetal )
          ::oLabInfo:SetText("No se actualizaron los detalles" )
          uResp := .F.
       endif
       if VAL(::hDocumento["numero"])>0
          ::oLabNumero:SetValue( STRZERO( VAL(::hDocumento["numero"]), 8) )
       else
          ::oLabNumero:SetValue( ALLTRIM(::hDocumento["numero"]) )
       endif
       if ::lNew
          ::lNew := .F.
    
      endif
   else
       uResp := .F.
   endif

if uResp
       ::cPreEstado := LEFT( ::oComboEstado:GetValue(), 1 )
       ::oLabInfo:SetText( "Actualizado." )
       __NEModDocsRefresh( oForm )
    endif
    
    
 return



procedure __NEModDocsRefresh(oForm)
   local aLine, aIter := ARRAY(4)
   local bDetalCode, aData

   ::rDocumentos := ::rVentas:Transacciones( ::cTipoDocumento )
   if hb_isObject( ::oModFacturas )
      ::oModFacturas:oTreeView:ClearModel(.t.)
      aData := ::rDocumentos:GetData()
      if Empty(aData) ; return ; endif
      FOR EACH aLine IN aData
          APPEND LIST_STORE ::oModFacturas:oLbx ITER aIter ;
                 VALUES aLine[ 1], hb_ntos(aLine[ 2]), ;
                        ALLTRIM(aLine[ 3]), DTOC(aLine[ 4]), ;
                        DTOC(aLine[ 5]), TRANSFORM(aLine[ 6],P_92), ;
                        aLine[ 7], hb_ntos(aLine[ 8]), ;
                        hb_ntos(aLine[ 9]), aLine[ 10], ;
                        aLine[ 11], aLine[ 12]
      NEXT
   endif
return




procedure __NESaveDetal(oTView, pModel, aIter, oForm)
   local hDetal := hb_hash()

   hDetal["numero"           ] := ::hDocumento[ "numero" ]
   hDetal["codigo_local"     ] := ALLTRIM(oTView:GetAutoValue( 03, aIter ))
   hDetal["descripcion"      ] := oTView:GetAutoValue( 04, aIter )
   hDetal["cantidad"         ] := VAL( oTView:GetAutoValue( 05, aIter ) )
   hDetal["precio_unitario"  ] := VAL( oTView:GetAutoValue( 06, aIter ) )
   hDetal["descuento"        ] := VAL( oTView:GetAutoValue( 07, aIter ) )
   hDetal["subtotal"         ] := VAL( oTView:GetAutoValue( 08, aIter ) )
   hDetal["iva_porcentaje"   ] := VAL( oTView:GetAutoValue( 09, aIter ) )
   hDetal["iva_monto"        ] := VAL( oTView:GetAutoValue( 10, aIter ) )
   hDetal["total"            ] := VAL( oTView:GetAutoValue( 11, aIter ) )
   hDetal["nombre_global"    ] := oTView:GetAutoValue( 12, aIter )
   hDetal["tipo_inventario"  ] := oTView:GetAutoValue( 13, aIter )
   hDetal["lote"             ] := ALLTRIM(oTView:GetAutoValue( 14, aIter ))
   hDetal["fecha_vencimiento"] := oTView:GetAutoValue( 15, aIter )
   hDetal["ubicacion"        ] := ALLTRIM(oTView:GetAutoValue( 16, aIter ))
   hDetal["almacen_id"       ] := ALLTRIM(oTView:GetAutoValue( 17, aIter ))
   hDetal["nombre_almacen"   ] := oTView:GetAutoValue( 18, aIter )
   hDetal["detalles_json"    ] := oTView:GetAutoValue( 19, aIter )
   hDetal["item"             ] := oTView:GetAutoValue( 20, aIter )
   hDetal["imp_pvp"          ] := oTView:GetAutoValue( 21, aIter )
    hDetal["imp_produccion"] := VAL( oTView:GetAutoValue( 24, aIter ) ) // Add imp_produccion
//View( oTView:GetAutoValue(20, aIter) )

   AADD( ::aDetal, hDetal )
return




