          ID "ent_monbase" RESOURCE ::oRes 
   ::oEntMonBase:Justify( GTK_JUSTIFY_RIGHT )

   DEFINE BOX ::oBoxIvaExe ID "box_ivaexe" RESOURCE ::oRes 
   ::nMontoIvaE := 0
   DEFINE MONEY ENTRY ::oEntIvaE VAR ::nMontoIvaE ;
          ID "ent_exento" RESOURCE ::oRes 
   ::oEntIvaE:Justify( GTK_JUSTIFY_RIGHT )

   DEFINE BOX ::oBoxIvaRed ID "box_ivared" RESOURCE ::oRes 
   ::nMontoIvaR := 0
   DEFINE MONEY ENTRY ::oEntIvaR VAR ::nMontoIvaR ;
          ID "ent_ivared" RESOURCE ::oRes 
   ::oEntIvaR:Justify( GTK_JUSTIFY_RIGHT )

   DEFINE BOX ::oBoxIvaGen ID "box_ivagen" RESOURCE ::oRes 
   ::nMontoIvaG := 0
   DEFINE MONEY ENTRY ::oEntIvaG VAR ::nMontoIvaG ;
          ID "ent_ivagen" RESOURCE ::oRes 
   ::oEntIvaG:Justify( GTK_JUSTIFY_RIGHT )

   DEFINE BOX ::oBoxIvaSun ID "box_ivasun" RESOURCE ::oRes 
   ::nMontoIvaS := 0
   DEFINE MONEY ENTRY ::oEntIvaS VAR ::nMontoIvaS ;
          ID "ent_ivasun" RESOURCE ::oRes 
   ::oEntIvaS:Justify( GTK_JUSTIFY_RIGHT )

   DEFINE BOX ::oBoxOtrImp ID "box_otrimp" RESOURCE ::oRes 
   ::nMontoOtrImp := 0
   DEFINE MONEY ENTRY ::oEntOtrImp VAR ::nMontoOtrImp ;
          ID "ent_otrimp" RESOURCE ::oRes 
   ::oEntOtrImp:Justify( GTK_JUSTIFY_RIGHT )
   ::oEntOtrImp:SetEditable( .F. )
   
   DEFINE BOX ::oBoxImpProd ID "box_impprod" RESOURCE ::oRes 
   ::nMontoImpProd := 0
   DEFINE MONEY ENTRY ::oEntImpProd VAR ::nMontoImpProd ;
          ID "ent_impprod" RESOURCE ::oRes 
   ::oEntImpProd:Justify( GTK_JUSTIFY_RIGHT )
   ::oEntImpProd:SetEditable( .F. )

   ::nMontoTotal := 0
   DEFINE MONEY ENTRY ::oEntTotal VAR ::nMontoTotal ;
          ID "ent_montotal" RESOURCE ::oRes 
   ::oEntTotal:Justify( GTK_JUSTIFY_RIGHT )
   ::oEntTotal:SetEditable( .F. )

   DEFINE MODEL  ::oModFacturas ;
          STRUCT ::rDocumentos:Struct() ;
          DATA   ::rDocumentos:GetData()
   DEFINE LISTBOX ::oLBoxFacs ;
          MODEL   ::oModFacturas ;
          OF      ::oBoxData
   ::oLBoxFacs:lBar  := .f.
   ::oLBoxFacs:bEdit := {|oModel| __vtaNotaEntrega( oForm, oFormParent, ::oBoxFactura, oModel, .F. ) }
   ::oLBoxFacs:Active() 
   ::oLBoxFacs:SetColVisible( 2, .f. )
   ::oLBoxFacs:SetColTitle( 3, "Cliente" )
   ::oLBoxFacs:SetColTitle( 5, "fecha de vcmto." )
   ::oLBoxFacs:SetColTitle( 6, "monto base" )

   ::hCol := hb_hash()
   ::hCol["numero"]           := 1
   ::hCol["cliente_id"]       := 2
   ::hCol["cliente"]          := 3
   ::hCol["fecha"]            := 4
   ::hCol["fecha_vcmto"]      := 5
   ::hCol["monto_base"]       := 6
   ::hCol["estado"]           := 7
   ::hCol["vendedor_id"]      := 8
   ::hCol["condicion_id"]     := 9
   ::hCol["condicion_nombre"] := 10
   ::hCol["serie_id"]         := 11
   ::hCol["serie_fiscal"]     := 12
   DEFINE BUTTON ::oBtnSalir ACTION ::oNotaWnd:End();
          ID "btn_salir" RESOURCE ::oRes
   ACTIVATE WINDOW ::oNotaWnd MODAL VALID __NEDocExit(oForm)
 return



procedure __NE_Docs( oForm )
rFacturas := ::rDocumento:Facturas( ::cCodCli )

   if ::hDocumento["estado"] = "C"
      RETURN
   endif

   if !hb_isObject(rFacturas)
      MsgAlert( "No hay facturas disponibles para este cliente" )
      RETURN
   endif

   if rFacturas:RecCount() = 0
      MsgAlert( "No hay facturas disponibles para este cliente" )
      RETURN
   endif

   if rFacturas:RecCount() = 1
      if hb_isNIL( rFacturas:factura_numero )
         MsgAlert( "No hay facturas disponibles para este cliente" )
         RETURN
      endif
      ::oEntFacturaNro:SetText( ALLTRIM(rFacturas:factura_numero) )
      ::rDocumento:SetRefNumero( ALLTRIM(rFacturas:factura_numero) )
      ::rFactDetal := ::rDocumento:DetalFrom()
      __NEDetalRefresh( oForm )
      return
   endif

   if rFacturas:RecCount() = 1
      ::oEntFacturaNro:SetText( ALLTRIM(rFacturas:factura_numero) )
      ::rDocumento:SetRefNumero( ALLTRIM(rFacturas:factura_numero) )
      ::rFactDetal := ::rDocumento:Detal()
      __NEDetalRefresh( oForm )
      return
   endif

SET RESOURCES oRes FROM FILE oTPuy:cResources+"vta_listbox.ui"
