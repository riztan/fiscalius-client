   DEFINE BOX ::oBoxDivisa ID "box_divisa" RESOURCE ::oRes
   ::aMonedas := {}
   ::aDivisas := {} //{"USD 723,1123", "EU 811,9908"}
   __OrdEntValFecha( oForm, ::oEntFecha, @::cPFecha )
   nMonedaRef := hb_DefaultValue( ::rEmpresa:GetData()["moneda_referencia_id"], 1 )
   nPosMoneda := ASCAN( ::aMonedas, {|x| x == nMonedaRef } )
   if nPosMoneda == 0
      nPosMoneda := 1
   endif
   if nPosMoneda <= LEN( ::aDivisas )
      ::cDivisa := ::aDivisas[nPosMoneda]
      ::nTasa := ToNum( hb_aTokens( ::cDivisa, " ")[2] )
   else
      ::cDivisa := ""
      ::nTasa   := 0
   endif
   DEFINE COMBOBOX ::oComboDivisa ;
          VAR ::cDivisa ITEMS ::aDivisas ;
          ON CHANGE __OrdEntCalcula( oForm )   ;
          OF ::oBoxDivisa

