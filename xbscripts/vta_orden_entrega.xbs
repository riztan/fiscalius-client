   ::lNew     := .T.
   ::lSilence := .F.
   ::oFormParent := oFormParent

   // Inicializar filtro según parámetro
   ::cFiltroEstado := "Todas"
   if !hb_isNIL( cFiltro )
      do case
      case upper( cFiltro ) == "ACTIVAS"
         ::cFiltroEstado := "Activas"
      case upper( cFiltro ) == "FINALIZADAS"
         ::cFiltroEstado := "Finalizadas"
      endcase
   endif

   ::aDetal := {}

   ::cEmpresa  := oFormParent:cCBEmpresa
   ::rEmpresa  := oFormParent:oGEmpresa
   ::rVentas   := oFormParent:oGEmpresa:SetModulo("Ventas")
   if upper( ::cFiltroEstado ) == "TODAS"
      ::rOrdEnt := ::rVentas:OrdenesEntrega()
   else
      ::rOrdEnt := ::rVentas:OrdenesEntrega( { "estado" => upper(::cFiltroEstado) } )
   endif
  
   if hb_isNIL( ::rOrdEnt )
      MsgStop( "no se puede obtener información de guías de despacho" )
      Return 
   endif


