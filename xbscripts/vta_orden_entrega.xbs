   //-------------------------
   // Extender struct con columnas calculadas para estatus y doc relacionado
   ::aOrdEntStruct := ::rOrdEnt:Struct()
   AADD( ::aOrdEntStruct, {"status_text", "C", 20, 0} )         // col 18
   AADD( ::aOrdEntStruct, {"doc_relacionado", "C", 50, 0} )     // col 19

   ::aOrdEntData := ::rOrdEnt:GetData()
   // Extender cada fila con status y doc_relacionado computados
   FOR EACH aRow IN ::aOrdEntData
      do case
      case aRow[7] == "B"
         AADD( aRow, "Borrador" )
      case aRow[7] == "A"
         AADD( aRow, "Anulada" )
      case aRow[7] == "C"
         if empty( aRow[14] )
            AADD( aRow, "Activa" )
         else
            AADD( aRow, "Finalizada" )
         endif
      otherwise
         AADD( aRow, "Desconocido" )
      endcase
      if empty( aRow[14] )
         AADD( aRow, "" )
      else
         do case
         case aRow[16] == 4
            AADD( aRow, "Factura Nro " + ALLTRIM( aRow[15] ) )
         case aRow[16] == 5
            AADD( aRow, "N/C Nro " + ALLTRIM( aRow[15] ) )
         case aRow[16] == 6
            AADD( aRow, "N/D Nro " + ALLTRIM( aRow[15] ) )
         otherwise
            AADD( aRow, "Doc. Nro " + ALLTRIM( aRow[15] ) )
         endcase
      endif
   NEXT

   DEFINE MODEL  ::oModOrdEnts ;
          STRUCT ::aOrdEntStruct ;
          DATA   ::aOrdEntData
   
   DEFINE LISTBOX ::oLBoxOrdEnts ;
          MODEL   ::oModOrdEnts ;
