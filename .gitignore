# Fiscalius Client - .gitignore para gh-pages

# Archivos de sistema
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Archivos de editor
.vscode/
.idea/
*.swp
*.swo
*~

# Archivos temporales
tmp/
temp/
*.tmp
*.bak

# Gemfile.lock (opcional para GitHub Pages)
Gemfile.lock

# Archivos de build
_site/
.jekyll-cache/
.jekyll-metadata
.sass-cache/

# Archivos de docs (se incluyen selectivamente)
docs/*.md
!docs/index.html

# Archivos de imágenes que no necesitamos en el sitio
images/*.png
images/*.jpg
images/*.gif
# Excepción: copiamos los logos que necesitamos
!assets/images/*.png

# Archivos de configuración
*.conf
init.conf
email.ch.example

# Archivos de scripts
xbscripts/
resources/
bin/

# Archivos de.cursor y .github
.cursor/
.github/
.opencode/
